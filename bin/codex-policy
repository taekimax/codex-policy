    "vendor/tomlkit/parser.py",
    "vendor/tomlkit/py.typed",
    "vendor/tomlkit/source.py",
    "vendor/tomlkit/toml_document.py",
    "vendor/tomlkit/toml_file.py",
}
REVIEWED_ARTIFACT_HASHES = {
    "global/AGENTS.md": "c3aa543906d51a8101c0a3347a2680657a9e249ee6b1098d64a77ea1d7de1132",
    "global/official-skills.json": "190c831c4fa7e23b0f0c2aa362819492d4bbb3985f9308272153f200221f83f3",
    "global/skills/oracle-solver/SKILL.md": "f5b385a69aca1066c35ecfae7317792b625fb3d33e7067099463fd05f337731a",
