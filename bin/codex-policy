try:
    import fcntl  # type: ignore
except ImportError:
    fcntl = None  # type: ignore


sys.dont_write_bytecode = True
REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO_ROOT / "vendor"))

try:
    import tomlkit  # type: ignore
except Exception:
    print("codex-policy: bundled TOML parser is unavailable", file=sys.stderr)
    raise SystemExit(2)


SCHEMA = 1
POLICY_SOURCE = REPO_ROOT / "global" / "AGENTS.md"
CONFIG_SOURCE = REPO_ROOT / "global" / "config.owned.toml"
OWNED_SOURCE = REPO_ROOT / "global" / "owned-keys.txt"
TARGET_NAMES = ("AGENTS.md", "config.toml")
INCOMPLETE_STATES = {"prepared", "applying", "recovery_required"}
MAX_TARGET_BYTES = 16 * 1024 * 1024
MAX_REPO_BYTES = 1024 * 1024
EXPECTED_OWNED_KEYS = {
    "agents.max_threads",
    "agents.max_depth",
    "agents.job_max_runtime_seconds",
}

CANONICAL_SSH_ORIGIN = "git@github.com:taekimax/codex-policy.git"
CANONICAL_HTTPS_ORIGIN = "https://github.com/taekimax/codex-policy"

EXPECTED_FILES = {
    ".gitattributes",
    ".github/workflows/verify.yml",
    ".gitignore",
    "AGENTS.md",
    "README.md",
    "SECURITY.md",
    "bin/codex-policy",
    "bin/codex-skills-policy",
    "global/AGENTS.md",
    "global/config.owned.toml",
    "global/official-skills.json",
    "global/owned-keys.txt",
    "global/skills/oracle-solver/SKILL.md",
    "global/skills/oracle-solver/agents/openai.yaml",
    "global/skills/oracle-solver/scripts/run_oracle.py",
    "tests/test_acceptance.py",
    "vendor/tomlkit/LICENSE",
